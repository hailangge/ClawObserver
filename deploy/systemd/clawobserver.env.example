# ClawObserver runtime configuration
# Default bind is loopback-only. Change this only if you intentionally want remote access.
CLAWOBSERVER_HOST=127.0.0.1
CLAWOBSERVER_PORT=8420

# UI live refresh interval in seconds. The frontend enforces a 30-second
# minimum for automatic polling, so the shipped deployment default matches it.
CLAWOBSERVER_REFRESH_SECONDS=30

# Archive cadence label used by the UI and expected by the systemd timer.
CLAWOBSERVER_ARCHIVE_CADENCE_MINUTES=30
CLAWOBSERVER_DATA_DIR=__HOME__/.local/state/clawobserver
CLAWOBSERVER_DATABASE_PATH=__HOME__/.local/state/clawobserver/clawobserver.sqlite3

# Runtime source precedence inside ClawObserver:
# 1. CLAWOBSERVER_RUNTIME_COMMAND
# 2. CLAWOBSERVER_RUNTIME_JSON
# 3. Built-in demo payload
CLAWOBSERVER_RUNTIME_COMMAND=/usr/bin/env python3 __REPO_ROOT__/scripts/openclaw_runtime_adapter.py
# CLAWOBSERVER_RUNTIME_JSON=/absolute/path/to/runtime.json
