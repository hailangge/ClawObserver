# ClawObserver runtime configuration
CLAWOBSERVER_HOST=127.0.0.1
CLAWOBSERVER_PORT=8420
CLAWOBSERVER_REFRESH_SECONDS=15
CLAWOBSERVER_ARCHIVE_CADENCE_MINUTES=30
CLAWOBSERVER_DATA_DIR=__HOME__/.local/state/clawobserver
CLAWOBSERVER_DATABASE_PATH=__HOME__/.local/state/clawobserver/clawobserver.sqlite3
CLAWOBSERVER_RUNTIME_COMMAND=/usr/bin/env python3 __REPO_ROOT__/scripts/openclaw_runtime_adapter.py
